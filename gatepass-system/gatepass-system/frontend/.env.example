# Only needed when the frontend and backend are deployed as separate
# services on different domains (e.g. two separate Render services).
#
# Leave this UNSET for local development — Vite's dev server proxies
# "/api" requests to http://localhost:4000 automatically (see vite.config.js).
#
# In production, set this to your backend's full URL, with no trailing slash:
VITE_API_URL=https://your-backend-service.onrender.com
